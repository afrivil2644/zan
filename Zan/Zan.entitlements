<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Hardened Runtime (required for notarization) gates device access;
         the app records the mic for dictation, so it needs this entitlement.
         Accessibility (for synthesized Cmd+C / Cmd+V) is TCC-based and needs
         no entitlement. The app is not sandboxed. -->
    <key>com.apple.security.device.audio-input</key>
    <true/>
</dict>
</plist>
